# MyAnimeList API Configuration (no longer required for core functionality)
# 
# 1. Go to https://myanimelist.net/apiconfig
# 2. Create a new app (you can select "Other" as the type)
# 3. Copy the "Client ID" (not the Client Secret)
# 4. Paste it below (only needed if you want to re-enable official API features in the future)

MAL_CLIENT_ID=your_mal_client_id_here

# No external ID mapping service is required.
# MAL ↔ IMDb mappings are loaded at startup from:
# https://github.com/Kometa-Team/Anime-IDs (anime_ids.json)
# No API key needed.

# Optional: You can add other configuration here in the future
# PORT=3000